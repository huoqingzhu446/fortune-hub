APP_DOMAIN=fortune.example.com
ENABLE_HTTPS=true
SSL_CERT_SOURCE=/data/certs/fullchain.pem
SSL_KEY_SOURCE=/data/certs/privkey.pem
DEPLOY_BRANCH=main

MYSQL_BIND_HOST=127.0.0.1
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=fortune_hub
MYSQL_USER=fortune
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-mysql-root-password

REDIS_BIND_HOST=127.0.0.1
REDIS_HOST=redis
REDIS_PORT=6379

API_PORT=3001
DB_SYNCHRONIZE=false
DB_RUN_MIGRATIONS=true
NGINX_BIND_HOST=0.0.0.0
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
CORS_ORIGIN=https://fortune.example.com

ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=Fortune Hub 管理员

FILE_SERVICE_BASE_URL=https://fortune.example.com/file-api/api
PUBLIC_API_BASE_URL=https://fortune.example.com/api/v1
PAYMENT_MODE=disabled
PAYMENT_MOCK_ENABLED=false
SMS_PROVIDER=aliyun
SMS_MOCK_ENABLED=false
SMS_MOCK_CODE=
SMS_CODE_PEPPER=use-a-long-random-sms-pepper
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MINI_PROGRAM_ENV_VERSION=release
WECHAT_WXACODE_WIDTH=430
POSTER_MINI_PROGRAM_CODE_ENABLED=true
POSTER_MINI_PROGRAM_CODE_URL=
POSTER_MINI_PROGRAM_CODE_REQUIRED=false
POSTER_WXACODE_STRICT_PATH=true
POSTER_WXACODE_ALLOWED_PAGES=pages/index/index,pages/zodiac/index,pages/lucky/sign/index,pages/divination/index/index,pages/report/index
POSTER_ZODIAC_TODAY_WXACODE_PATH=pages/zodiac/index?zodiac={zodiac}
POSTER_LUCKY_SIGN_WXACODE_PATH=pages/lucky/sign/index?bizCode={sourceCode}
ZHIPU_API_KEY=
BIGMODEL_API_KEY=
ZHIPU_IMAGE_MODEL=glm-image
ZHIPU_WALLPAPER_SIZE_9_16=1088x1472
ZHIPU_WALLPAPER_SIZE_16_9=1472x1088
ZHIPU_WALLPAPER_SIZE_1_1=1280x1280
