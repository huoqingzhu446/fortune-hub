VITE_API_BASE_URL=http://localhost:3001/api/v1
VITE_MP_WEIXIN_API_BASE_URL=https://your-domain.example/api/v1
VITE_FILE_SERVICE_BASE_URL=http://localhost:3000/api
VITE_MP_WEIXIN_FILE_SERVICE_BASE_URL=https://your-domain.example/file-api/api
VITE_PAYMENT_MODE=disabled

