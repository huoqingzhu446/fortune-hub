{
  "name": "fortune-hub",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev:mobile": "pnpm --filter @fortune-hub/mobile dev:mp-weixin",
    "dev:mobile:h5": "pnpm --filter @fortune-hub/mobile dev:h5",
    "dev:admin": "pnpm --filter @fortune-hub/admin dev",
    "dev:api": "node scripts/dev-api.mjs",
    "build:mobile": "pnpm --filter @fortune-hub/mobile build:mp-weixin",
    "build:mobile:h5": "pnpm --filter @fortune-hub/mobile build:h5",
    "build:admin": "pnpm --filter @fortune-hub/admin build",
    "build:api": "pnpm --filter @fortune-hub/api build",
    "build": "pnpm build:mobile && pnpm build:mobile:h5 && pnpm build:admin && pnpm build:api",
    "type-check:mobile": "pnpm --filter @fortune-hub/mobile type-check",
    "test:api": "pnpm --filter @fortune-hub/api test",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  }
}
